# Force LF for every text file, in the repo AND in every working copy on all
# platforms (Linux/macOS/Windows). `eol=lf` overrides core.autocrlf, so there is
# no CRLF conversion anywhere — which is what kills the "LF will be replaced by
# CRLF" warnings on Windows. Rust, cargo, and modern editors handle LF natively.
* text=auto eol=lf

# Explicit text types (normalized to LF in the repo).
*.rs    text
*.toml  text
*.lock  text
*.md    text
*.yml   text
*.yaml  text
*.json  text
*.html  text
*.wgsl  text
*.glsl  text
*.txt   text
*.gitattributes text
*.gitignore     text

# Binary types — never munge line endings.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.vox   binary
*.ttf   binary
*.otf   binary
*.bin   binary
*.zip   binary
